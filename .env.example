# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=bedrock

# ── OpenRouter (optional fallback provider config) ──────────────────────────
# Get a free API key at https://openrouter.ai → Dashboard → Keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ── AWS secret loading (optional, recommended on EC2) ───────────────────────
# Attach an IAM role to the EC2 instance, then point Hermes at SSM / Secrets Manager.
# SSM path example: /hermes/prod
# Store parameters like /hermes/prod/TELEGRAM_BOT_TOKEN and /hermes/prod/APPLE_APP_PASSWORD
AWS_REGION=us-east-1
HERMES_AWS_SSM_PATH=
# Optional Secrets Manager secret ID or ARN.
# Supported secret formats:
# - JSON object, e.g. {"OPENROUTER_API_KEY":"...","TELEGRAM_BOT_TOKEN":"..."}
# - dotenv text, e.g. OPENROUTER_API_KEY=...\nTELEGRAM_BOT_TOKEN=...
HERMES_AWS_SECRET_ID=
# Only needed if the Secrets Manager secret is a single raw string instead of JSON/dotenv.
HERMES_AWS_SECRET_ENV_NAME=

# ── Amazon Bedrock (primary LLM agent) ──────────────────────────────────────
BEDROCK_API_KEY=bedrock-api-key
BEDROCK_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
BEDROCK_MODEL=qwen.qwen3-next-80b-a3b-instruct
BEDROCK_VISION_MODEL=qwen.qwen3-vl-235b-a22b-instruct
VOICE_TRANSCRIBE_MODEL=openai/gpt-audio-mini

# ── D2L / Slate ─────────────────────────────────────────────────────────────
SLATE_URL=https://slate.sheridancollege.ca
SLATE_EMAIL=your.email@sheridancollege.ca   # Microsoft SSO email

# Session state file (auto-created after first auth run)
SLATE_SESSION_FILE=~/.hermes/slate_session.json

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Talk to @BotFather on Telegram → /newbot → copy the token below
# 2. Send any message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPQRsTuVwXyZ
TELEGRAM_CHAT_ID=987654321

# ── Apple Reminders (iCloud CalDAV) ─────────────────────────────────────────
# 1. Go to https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
# 2. Generate a password and paste it below (do NOT use your main Apple password)
APPLE_ID=your@icloud.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Optional: target specific Apple Reminders list / Apple Calendar by name
APPLE_REMINDERS_NAME=
APPLE_CALENDAR_NAME=

# ── Browser automation ───────────────────────────────────────────────────────
# Set Browser Use as primary and keep a fallback backend for when it is unavailable.
BROWSER_BACKEND=browser-use
BROWSER_FALLBACK_BACKEND=local

# Local Playwright settings
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=15000
BROWSER_IDLE_TIMEOUT_SECONDS=20
BROWSER_MAX_SESSION_SECONDS=120
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_PROFILE_DIR=~/.hermes/browser-profile
BROWSER_SCREENSHOT_DIR=~/hermes-screenshots
BROWSER_DOWNLOAD_DIR=~/hermes-downloads

# Browser Use settings (used when BROWSER_BACKEND=browser-use)
BROWSER_USE_API_KEY=
BROWSER_USE_CONNECT_BASE=wss://connect.browser-use.com
BROWSER_USE_PROFILE_ID=
BROWSER_USE_PROXY_COUNTRY_CODE=
BROWSER_USE_TIMEOUT_MINUTES=2

# Browserbase settings (used when Browserbase is the selected backend or fallback)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_REGION=
BROWSERBASE_TIMEOUT_SECONDS=120
BROWSERBASE_KEEP_ALIVE=false
# Reuse an existing Browserbase context to preserve login state between sessions.
BROWSERBASE_CONTEXT_ID=
BROWSERBASE_CONTEXT_PERSIST=true
# Optional JSON, for example `true` or `{"country":"CA"}`.
BROWSERBASE_PROXIES=
BROWSERBASE_ADVANCED_STEALTH=
BROWSERBASE_BLOCK_ADS=
BROWSERBASE_SOLVE_CAPTCHAS=
BROWSERBASE_RECORD_SESSION=
BROWSERBASE_LOG_SESSION=
BROWSERBASE_OS=

# Browser login secrets
# Store site credentials here locally, then reference them in browser_type as env:VAR_NAME.
# Example:
# MY_SITE_EMAIL=you@example.com
# MY_SITE_PASSWORD=replace-me

# ── Checker schedule ─────────────────────────────────────────────────────────
# How often to poll Slate (in minutes). Default: 60
CHECK_INTERVAL_MINUTES=60

# Warn about assignments due within this many days
REMINDER_DAYS_AHEAD=3

# Where to save downloaded assignment docs
DOCS_DIR=~/hermes-docs

# Mac -> EC2 Slate session sync
HERMES_HOST=ubuntu@your-server-ip
HERMES_SSH_KEY=~/.ssh/your-key.pem
HERMES_REMOTE_REPO=~/hermes
HERMES_REMOTE_SLATE_SESSION_FILE=~/.hermes/slate_session.json
