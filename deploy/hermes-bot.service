[Unit]
Description=Hermes Telegram Agent Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__HERMES_DIR__
Environment="PATH=__VENV_DIR__/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=__HERMES_DIR__/.env
ExecStart=__VENV_DIR__/bin/python deploy/run_with_aws_env.py bot.telegram_bot
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes-bot

[Install]
WantedBy=multi-user.target
