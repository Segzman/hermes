{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadHermesSsmRuntimeParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParametersByPath"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/hermes/prod/*"
    },
    {
      "Sid": "ReadHermesSharedSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:*:*:secret:hermes/prod/shared*"
    }
  ]
}
